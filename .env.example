# Copy this file to .env.local for local development, and add the same
# keys (with real values) in Vercel → Project Settings → Environment Variables.

# Connection string from your Neon project (Vercel Storage tab -> Neon, or neon.tech directly)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# API key from https://platform.claude.com (Anthropic API console)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# The password you'll type once to unlock the app in your browser
APP_PASSWORD=choose-a-password

# Any long random string - used to sign the login session cookie, not shown to users
SESSION_SECRET=choose-a-long-random-string
